# Ollama Dashboard — copy to .env (loaded automatically on startup; shell env wins)

# --- Core ---
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_DASHBOARD_CONFIG=production
OLLAMA_DASHBOARD_HOST=127.0.0.1
OLLAMA_DASHBOARD_PORT=5000
AUTO_START_OLLAMA=true
LOG_LEVEL=INFO

# --- Data ---
HISTORY_FILE=data/history.json
MODEL_SETTINGS_FILE=data/model_settings.json
MAX_HISTORY=50

# --- Auth (optional) ---
ENABLE_AUTH=false
# API_KEY_VIEWER=
# API_KEY_OPERATOR=
# API_KEY_ADMIN=

# --- CORS / TLS ---
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
HTTPS_ENABLED=false

# --- Copilot / proxy (IDE clients use http://127.0.0.1:5000/ollama) ---
OLLAMA_PROXY_MAX_PREDICT=8192
OLLAMA_PROXY_MAX_PREDICT_AGENT=32768
OLLAMA_PROXY_STREAM_HEARTBEAT_SECONDS=5
OLLAMA_COPILOT_ALLOW_THINKING=true
CONTEXT_TRIM_ENABLED=true
COPILOT_PREWARM_MODEL=gemma4:latest
COPILOT_PREWARM_ON_START=true
COPILOT_KEEP_ALIVE=true
COPILOT_KEEP_ALIVE_MINUTES=15

# --- Benchmarks (parallel fleet runs; default 1 = sequential) ---
BENCHMARK_MAX_WORKERS=1
# POST /api/models/benchmark with {"compare": true} for dashboard vs raw Ollama lift report
# Response includes improvements.* with settings validation and agentic tuning advice

# --- Multi-model RAM residency (64GB+ systems: fast tier always loaded + heavy warm) ---
# Set on the OLLAMA SERVER process (Windows system env), then restart Ollama:
#   OLLAMA_MAX_LOADED_MODELS=2
#   OLLAMA_KEEP_ALIVE=-1
#   OLLAMA_NUM_PARALLEL=1
RESIDENCY_ON_START=true
RESIDENCY_FAST_MODEL=gemma4:latest
RESIDENCY_HEAVY_MODEL=qwen3.6:27B
RESIDENCY_KEEP_ALIVE=-1
RESIDENCY_HEAVY_KEEP_ALIVE=30m

# --- Agent / long sessions ---
ASK_AGENT_MAX_ITERATIONS=12
ASK_AGENT_TURN_TIMEOUT=180
ASK_AGENT_MAX_TOOL_ERRORS=3
ASK_AGENT_MAX_TOOL_REPEATS=3

# --- MCP (http://127.0.0.1:5000/mcp) ---
MCP_ALLOW_WRITE=true
